---
/**
 * Layout de base : <head> (SEO / Open Graph / JSON-LD), polices self-hostées,
 * styles globaux, analytics optionnel. Toutes les pages passent par ici.
 */

// Polices self-hostées (perf + pas de dépendance à Google Fonts au runtime).
import '@fontsource/anton'; // titres & logo (poids 400 unique)
import '@fontsource-variable/inter'; // corps de texte (variable)

import '../styles/global.css';
import { siteConfig } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'EBOK Basketball — la boîte à outils des basketteurs',
  description = 'Neuf outils pour les coachs, joueurs et clubs de basket francophones — du terrain à l\'analyse. L\'écosystème EBOK Basketball.',
} = Astro.props;

// URL canonique / OG absolue (repose sur `site` dans astro.config.mjs).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og-image.png', Astro.site).href;
const siteUrl = new URL('/', Astro.site).href;

// Données structurées (SEO) : aide les moteurs à comprendre le site.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'EBOK Basketball',
  description,
  url: siteUrl,
  logo: ogImage,
  email: siteConfig.contactEmail,
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#1f6fe5" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="EBOK Basketball" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Données structurées -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Analytics respectueux de la vie privée (activé si un domaine est configuré) -->
    {siteConfig.plausibleDomain && (
      <script
        defer
        data-domain={siteConfig.plausibleDomain}
        src="https://plausible.io/js/script.js"></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
