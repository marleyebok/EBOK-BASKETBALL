---
/**
 * Layout de base : <head> (SEO / Open Graph / JSON-LD / hreflang), polices
 * self-hostées, styles globaux, analytics optionnel. Toutes les pages passent
 * par ici. Bilingue via `Astro.currentLocale`.
 */
import '@fontsource/anton';
import '@fontsource-variable/inter';
import '../styles/global.css';

import { siteConfig } from '../config';
import { currentLang, useT, localizedPath, ogLocale, locales } from '../i18n';

interface Props {
  title?: string;
  description?: string;
}

const lang = currentLang(Astro.currentLocale);
const t = useT(lang);

const { title = t('meta.title'), description = t('meta.desc') } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og-image.png', Astro.site).href;
const siteUrl = new URL('/', Astro.site).href;

// Liens alternates (hreflang) vers la même page dans chaque langue.
const alternates = locales.map((l) => ({
  lang: l,
  href: new URL(localizedPath(Astro.url.pathname, l), Astro.site).href,
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'EBOK Basketball',
  description,
  url: siteUrl,
  logo: ogImage,
  email: siteConfig.contactEmail,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#1f6fe5" />

    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="EBOK Basketball" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale[lang]} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {siteConfig.plausibleDomain && (
      <script
        defer
        data-domain={siteConfig.plausibleDomain}
        src="https://plausible.io/js/script.js"></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
