---
/** Grille des 9 outils. */
import { TOOLS } from '../data/tools';
import ToolCard from './ToolCard.astro';
---

<section class="wrap" aria-label="Les outils de l'écosystème EBOK Basketball">
  <div class="grid">
    {TOOLS.map((tool, i) => <ToolCard tool={tool} index={i} />)}
  </div>
</section>
