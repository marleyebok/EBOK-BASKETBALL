---
/**
 * Une carte d'outil : logo, statut (pastille LED néon), description visible,
 * et un appel à l'action. Fond/bordure teintés à la couleur de l'outil.
 * Textes localisés via `Astro.currentLocale`.
 */
import type { Tool } from '../data/tools';
import { currentLang, useT } from '../i18n';
import ToolLogo from './ToolLogo.astro';

interface Props {
  tool: Tool;
  /** Index pour l'animation d'apparition décalée. */
  index?: number;
}
const { tool, index = 0 } = Astro.props;

const lang = currentLang(Astro.currentLocale);
const t = useT(lang);

const statusLabel = t(`status.${tool.status}` as 'status.on');
const ctaLabel = t(`cta.${tool.status}` as 'cta.on');
const ctaOnline = tool.status === 'on';

const hasLink = Boolean(tool.url && tool.url !== '#');
const Tag = hasLink ? 'a' : 'div';
---

<Tag
  class="card"
  style={`--c:${tool.color}; --i:${index}`}
  {...hasLink ? { href: tool.url } : {}}
  aria-label={`EBOK ${tool.name} — ${statusLabel}`}
>
  <div class="card-head">
    <ToolLogo name={tool.name} color={tool.color} />
    <span class={`status st-${tool.status}`}><span class="led"></span>{statusLabel}</span>
  </div>
  <p class="card-desc">{tool.description[lang]}</p>
  <span class:list={['card-cta', { soon: !ctaOnline }]}>
    {ctaLabel}
    {ctaOnline && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
    )}
  </span>
</Tag>
