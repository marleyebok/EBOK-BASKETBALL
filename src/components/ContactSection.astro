---
/** Section contact (bas de page). */
const email = 'Ebok.basket@gmail.com';
---

<section class="section contact wrap" aria-labelledby="contact-title">
  <p class="eyebrow">Un besoin · Une idée · Un outil</p>
  <h2 id="contact-title">Construisons la suite ensemble</h2>
  <p>
    Acteurs et passionnés du basket français : toute demande de collaboration
    est la bienvenue.
  </p>
  <a class="btn" href={`mailto:${email}`}>
    <span aria-hidden="true">✉</span>
    Nous écrire
  </a>
</section>
