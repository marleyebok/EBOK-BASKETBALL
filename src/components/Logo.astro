---
/**
 * Logo « EBOK BASKETBALL » recréé en SVG vectoriel (fond transparent).
 *
 * Pourquoi un SVG plutôt que le PNG fourni : net à toute taille, ultra léger,
 * transparent, et modifiable. Pour utiliser le vrai fichier de marque, dépose
 * `EBOK_Basketball_Logo_transparent.png` dans /public et remplace le <svg>
 * ci-dessous par : <img src="/EBOK_Basketball_Logo_transparent.png" alt="EBOK Basketball" />
 *
 * Le texte utilise la police Anton (chargée globalement), fidèle au lettrage
 * condensé et gras de la marque.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 1000 200"
  role="img"
  aria-label="EBOK Basketball"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <clipPath id="ebok-pill">
      <rect x="8" y="8" width="984" height="184" rx="92" ry="92" />
    </clipPath>
  </defs>

  <!-- Corps de la pastille : contour noir, intérieur transparent -->
  <rect
    x="8"
    y="8"
    width="984"
    height="184"
    rx="92"
    ry="92"
    fill="none"
    stroke="#0a0a0a"
    stroke-width="12"
  />

  <!-- Zone noire de gauche avec séparation courbe, découpée par la pastille -->
  <g clip-path="url(#ebok-pill)">
    <path d="M0 0 L372 0 C 338 66, 338 134, 372 200 L0 200 Z" fill="#0a0a0a" />
  </g>

  <!-- EBOK (blanc, sur la zone noire) -->
  <text
    x="188"
    y="112"
    fill="#ffffff"
    font-family="'Anton', sans-serif"
    font-size="132"
    letter-spacing="2"
    text-anchor="middle"
    dominant-baseline="middle"
  >EBOK</text>

  <!-- BASKETBALL (noir, sur la zone claire) -->
  <text
    x="690"
    y="112"
    fill="#0a0a0a"
    font-family="'Anton', sans-serif"
    font-size="120"
    letter-spacing="1"
    text-anchor="middle"
    dominant-baseline="middle"
  >BASKETBALL</text>
</svg>
