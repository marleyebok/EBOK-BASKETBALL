---
/**
 * Le « système solaire » : le hub EBOK Basketball (ballon SVG qui tourne
 * lentement) au centre, 3 anneaux d'orbite en pointillé, et les 9 outils
 * répartis autour via ToolBubble.
 *
 * La position de chaque bulle est calculée ici à partir de son angle et de son
 * anneau (voir src/data/tools.ts), puis transmise en % à ToolBubble.
 */
import { TOOLS, RINGS } from '../data/tools';
import ToolBubble from './ToolBubble.astro';

/** Convertit angle (° depuis le haut, horaire) + rayon en coordonnées % (0–100). */
function place(angleDeg: number, radiusFraction: number) {
  const rad = (angleDeg * Math.PI) / 180;
  const r = radiusFraction * 100; // fraction → pourcentage du champ orbital
  const x = 50 + r * Math.sin(rad);
  const y = 50 - r * Math.cos(rad);
  return { x, y };
}

const placed = TOOLS.map((tool) => {
  const { x, y } = place(tool.angle, RINGS[tool.ring]);
  return { tool, x, y, openUp: y > 50 }; // moitié basse → pop vers le haut
});

// Diamètres (%) des anneaux d'orbite, pour les cercles pointillés.
const orbitDiameters = {
  inner: RINGS.inner * 2 * 100,
  middle: RINGS.middle * 2 * 100,
  outer: RINGS.outer * 2 * 100,
};
---

<section class="solar section" aria-label="La galaxie des outils EBOK Basketball">
  <div class="stage">
    <div class="field">
      <!-- Anneaux d'orbite (décoratifs) -->
      <div class="orbit" style={`--d:${orbitDiameters.outer}%`} aria-hidden="true"></div>
      <div class="orbit" style={`--d:${orbitDiameters.middle}%`} aria-hidden="true"></div>
      <div class="orbit" style={`--d:${orbitDiameters.inner}%`} aria-hidden="true"></div>

      <!-- Hub central : le ballon de basket -->
      <div class="hub">
        <span class="halo" aria-hidden="true"></span>

        <svg
          class="ball"
          viewBox="0 0 100 100"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <radialGradient id="ballSphere" cx="38%" cy="34%" r="72%">
              <stop offset="0%" stop-color="#ffffff" />
              <stop offset="70%" stop-color="#f4faff" />
              <stop offset="100%" stop-color="#e2f0ff" />
            </radialGradient>
          </defs>

          <!-- La sphère + les coutures tournent ensemble -->
          <g class="ball-spin">
            <circle cx="50" cy="50" r="46" fill="url(#ballSphere)" />
            <g
              fill="none"
              stroke="#5cc0ff"
              stroke-width="2"
              stroke-linecap="round"
            >
              <circle cx="50" cy="50" r="46" />
              <!-- couture verticale, légèrement décalée / asymétrique -->
              <path d="M50 4 C 44 30, 56 70, 50 96" />
              <!-- couture horizontale courbée -->
              <path d="M6 50 C 30 43, 70 57, 94 50" />
              <!-- deux grands arcs balayants (gauche / droite) -->
              <path d="M21 11 C 41 36, 41 64, 23 89" />
              <path d="M79 11 C 59 36, 59 64, 77 89" />
            </g>
          </g>
        </svg>

        <!-- Texte fixe au centre (ne tourne pas), avec plaque de lisibilité -->
        <div class="hub-label">
          <span class="hub-plate" aria-hidden="true"></span>
          <span class="hub-top">EBOK</span>
          <span class="hub-bottom">Basketball</span>
        </div>
      </div>

      <!-- Les 9 outils -->
      {placed.map(({ tool, x, y, openUp }) => (
        <ToolBubble tool={tool} x={x} y={y} openUp={openUp} />
      ))}
    </div>
  </div>
</section>

<style>
  .solar {
    display: flex;
    justify-content: center;
  }

  /* Scène : carrée, avec marge pour éviter que les bulles externes ne rognent. */
  .stage {
    position: relative;
    width: min(92vw, 720px);
    aspect-ratio: 1 / 1;
  }

  /* Champ orbital : repère de calcul des positions (86 % de la scène). */
  .field {
    position: absolute;
    inset: 7%;
  }

  /* ----- Anneaux d'orbite ---------------------------------------------- */
  .orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--d);
    height: var(--d);
    transform: translate(-50%, -50%);
    border: 1.5px dashed rgba(92, 192, 255, 0.55);
    border-radius: 50%;
  }

  /* ----- Hub central --------------------------------------------------- */
  .hub {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 30%;
    aspect-ratio: 1 / 1;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    z-index: 2;
  }

  .halo {
    position: absolute;
    inset: -22%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(92, 192, 255, 0.55) 0%,
      rgba(92, 192, 255, 0) 68%
    );
    animation: breathe 4.5s ease-in-out infinite;
  }

  @keyframes breathe {
    0%,
    100% {
      transform: scale(0.92);
      opacity: 0.65;
    }
    50% {
      transform: scale(1.08);
      opacity: 1;
    }
  }

  .ball {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 12px 24px rgba(16, 32, 46, 0.18));
  }

  .ball-spin {
    transform-origin: 50% 50%;
    animation: spin 20s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ----- Texte central fixe -------------------------------------------- */
  .hub-label {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    text-align: center;
    line-height: 1;
    pointer-events: none;
  }

  .hub-plate {
    position: absolute;
    inset: 50% 50% auto auto;
    width: 118%;
    height: 62%;
    transform: translate(50%, -50%);
    background: var(--plate);
    border-radius: 50%;
    filter: blur(6px);
    z-index: -1;
  }

  .hub-top {
    font-family: var(--font-title);
    color: #fff;
    font-size: clamp(1.1rem, 4.4vw, 2.1rem);
    letter-spacing: 0.04em;
    text-shadow: 0 2px 8px rgba(9, 40, 74, 0.7), 0 0 2px rgba(9, 40, 74, 0.9);
  }

  .hub-bottom {
    font-family: var(--font-title);
    color: #fff;
    font-size: clamp(0.7rem, 2.7vw, 1.25rem);
    letter-spacing: 0.06em;
    text-shadow: 0 2px 8px rgba(9, 40, 74, 0.7), 0 0 2px rgba(9, 40, 74, 0.9);
  }

  /* ===== Mobile (< 721px) : grille lisible à 2 colonnes ================ */
  @media (max-width: 720px) {
    .stage {
      width: 100%;
      aspect-ratio: auto;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .field {
      position: static;
      inset: auto;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.9rem;
    }

    /* Anneaux masqués sur mobile */
    .orbit {
      display: none;
    }

    /* Le ballon passe au-dessus de la grille, centré. On garde `relative`
       pour que le label et sa plaque restent ancrés dans le ballon. */
    .hub {
      position: relative;
      inset: auto;
      transform: none;
      width: min(58vw, 220px);
      margin: 0 auto;
      grid-column: 1 / -1;
    }
  }

  /* ----- Mouvement réduit ---------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .ball-spin,
    .halo {
      animation: none;
    }
  }
</style>
