---
/** Header : logo centré + sélecteur de langue à droite. */
import Logo from './Logo.astro';
import LangSwitch from './LangSwitch.astro';
import { currentLang, useT, localizedPath } from '../i18n';

const lang = currentLang(Astro.currentLocale);
const t = useT(lang);
const homeHref = localizedPath('/', lang);
---

<header class="site-header">
  <a href={homeHref} aria-label={t('nav.home')}>
    <Logo />
  </a>
  <LangSwitch />
</header>
