---
/**
 * Une bulle d'outil posée sur une orbite : badge « EBOK + nom », pastille de
 * statut à ondes concentriques, et fenêtre pop (infobulle) au survol / focus.
 *
 * Géométrie (position, sens d'ouverture) calculée par SolarSystem et passée
 * via des variables CSS pour pouvoir être neutralisée facilement en mobile.
 */
import { STATUSES, type Tool } from '../data/tools';

interface Props {
  tool: Tool;
  /** Position horizontale du centre de la bulle, en % du champ orbital. */
  x: number;
  /** Position verticale du centre de la bulle, en % du champ orbital. */
  y: number;
  /** true si la bulle est en moitié basse → la pop s'ouvre vers le haut. */
  openUp: boolean;
}

const { tool, x, y, openUp } = Astro.props;
const status = STATUSES[tool.status];
const fullName = `EBOK ${tool.name}`;
---

<div
  class="bubble"
  style={`--x:${x}%; --y:${y}%; --tool:${tool.color}; --pip:${status.color};`}
  data-open={openUp ? 'up' : 'down'}
>
  <a
    class="badge"
    href={tool.url}
    aria-label={`${fullName} — ${status.label}. ${tool.description}`}
  >
    <span class="tag">EBOK</span>
    <span class="tname">{tool.name}</span>
    <span class="pip" aria-hidden="true"></span>
  </a>

  <div class="pop" role="tooltip">
    <span class="pop-bar" aria-hidden="true"></span>
    <strong class="pop-title">{fullName}</strong>
    <span class="pop-status">{status.label}</span>
    <p class="pop-desc">{tool.description}</p>
  </div>
</div>

<style>
  /* Base = mobile-first : chaque bulle est une carte lisible qui coule dans
     la grille, description toujours visible (pas de survol sur tactile).
     Le comportement « infobulle flottante » est ajouté au desktop plus bas. */
  .bubble {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: flex-start;
    padding: 0.9rem;
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(90, 160, 220, 0.3);
    border-radius: var(--radius);
    z-index: 1;
  }

  /* ----- Badge --------------------------------------------------------- */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.5rem 0.3rem 0.35rem;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(90, 160, 220, 0.4);
    border-radius: 999px;
    box-shadow: 0 8px 20px -10px rgba(16, 32, 46, 0.45);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    transition: transform 0.16s ease, box-shadow 0.16s ease;
    white-space: nowrap;
  }

  .badge:hover,
  .badge:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 14px 26px -12px rgba(16, 32, 46, 0.55);
  }

  .tag {
    font-family: var(--font-title);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: #fff;
    background: #0e2233;
    padding: 0.18rem 0.34rem;
    border-radius: 6px;
  }

  .tname {
    font-family: var(--font-title);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--tool);
  }

  /* ----- Pastille de statut + ondes concentriques ---------------------- */
  .pip {
    position: relative;
    width: 11px;
    height: 11px;
    margin-left: 0.15rem;
    border-radius: 50%;
    background: var(--pip);
    flex: none;
  }

  .pip::before,
  .pip::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid var(--pip);
    animation: wave 2.2s ease-out infinite;
  }

  .pip::after {
    animation-delay: 1.1s;
  }

  @keyframes wave {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    100% {
      transform: scale(3.4);
      opacity: 0;
    }
  }

  /* ----- Fenêtre pop : base = carte statique lisible (mobile) ---------- */
  .pop {
    width: 100%;
    padding: 0.6rem 0 0;
    text-align: left;
    overflow: hidden;
  }

  /* Barre à la couleur de l'outil (petit trait en mobile) */
  .pop-bar {
    display: block;
    width: 32px;
    height: 4px;
    border-radius: 4px;
    background: var(--tool);
    margin-bottom: 0.5rem;
  }

  .pop-title {
    display: block;
    font-family: var(--font-title);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--ink);
    margin-top: 0.15rem;
  }

  .pop-status {
    display: inline-block;
    margin: 0.25rem 0 0.4rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--pip);
  }

  .pop-status::before {
    content: '● ';
  }

  .pop-desc {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--ink-soft);
  }

  /* ===== Desktop (≥ 721px) : orbite + infobulle flottante au survol ==== */
  @media (min-width: 721px) {
    /* La bulle redevient un simple point positionné sur son orbite. */
    .bubble {
      position: absolute;
      left: var(--x);
      top: var(--y);
      transform: translate(-50%, -50%);
      display: block;
      padding: 0;
      background: none;
      border: none;
    }

    /* La pop devient une infobulle flottante, cachée par défaut. */
    .pop {
      position: absolute;
      left: 50%;
      top: calc(100% + 12px);
      transform: translateX(-50%) translateY(6px);
      width: 216px;
      padding: 0.85rem 0.9rem 0.95rem;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 18px 40px -14px rgba(16, 32, 46, 0.5);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.16s ease, transform 0.16s ease;
      z-index: 5;
    }

    /* Barre supérieure pleine largeur en haut de la pop. */
    .pop-bar {
      position: absolute;
      inset: 0 0 auto 0;
      width: auto;
      height: 5px;
      margin: 0;
      border-radius: 0;
    }

    /* Petite flèche façon infobulle. */
    .pop::after {
      content: '';
      position: absolute;
      left: 50%;
      width: 12px;
      height: 12px;
      background: #fff;
      transform: translateX(-50%) rotate(45deg);
    }

    .bubble[data-open='down'] .pop::after {
      top: -6px;
    }

    /* Bulles de la moitié basse : la pop s'ouvre vers le haut. */
    .bubble[data-open='up'] .pop {
      top: auto;
      bottom: calc(100% + 12px);
      transform: translateX(-50%) translateY(-6px);
    }

    .bubble[data-open='up'] .pop::after {
      bottom: -6px;
      top: auto;
    }

    /* Révélation au survol / focus clavier. */
    .bubble:hover .pop,
    .bubble:focus-within .pop {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }

    .bubble:hover,
    .bubble:focus-within {
      z-index: 10;
    }
  }
</style>
